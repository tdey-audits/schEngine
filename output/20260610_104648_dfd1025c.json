    {
      "question": "If the equation $x^2 + 4x + k = 0$ has real and distinct roots, then",
      "answer": "(B)",
      "solution": {
        "steps": [
          "For distinct real roots, $D > 0$.",
          "$b^2 - 4ac > 0$.",
          "$4^2 - 4(1)(k) > 0$.",
          "$16 - 4k > 0 \\Rightarrow 16 > 4k \\Rightarrow k < 4$."
        ],
        "derivation": "$b^2 - 4ac > 0 \\\\ 16 - 4k > 0 \\\\ 4k < 16 \\\\ k < 4$"
      },
      "topic": "Quadratic Equations",
      "subtopic": "Nature of roots",
      "marks": 1,
      "type": "mcq",
      "difficulty": "simple",
      "options": [
        "(A) $k > 4$",
