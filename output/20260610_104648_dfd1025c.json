    {
      "question": "The quadratic equation $x^2 + 5x + 6 = 0$ has roots",
      "answer": "(B)",
      "solution": {
        "steps": [
          "Factorize the middle term: $x^2 + 3x + 2x + 6 = 0$.",
          "$x(x+3) + 2(x+3) = 0$.",
          "$(x+2)(x+3) = 0$.",
          "Roots are $x = -2$ and $x = -3$."
        ],
        "derivation": "$x^2 + 5x + 6 = 0 \\\\ x^2 + 3x + 2x + 6 = 0 \\\\ x(x+3) + 2(x+3) = 0 \\\\ (x+2)(x+3) = 0 \\\\ x = -2, -3$"
      },
      "topic": "Quadratic Equations",
      "subtopic": "Factorisation method",
      "marks": 1,
      "type": "mcq",
      "difficulty": "simple",
      "options": [
        "(A) $2, 3$",
        "(B) $-2, -3$",
        "(C) $1, 6$",
        "(D) $-1, -6$"
      ],
