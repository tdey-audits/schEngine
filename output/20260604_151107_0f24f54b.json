      "question": "Find the distance between the points $P(2, 3)$ and $Q(4, 1)$.",
      "answer": "$2\\sqrt{2}$ units",
      "solution": {
        "steps": [
          "Identify coordinates $x_1 = 2, y_1 = 3$ and $x_2 = 4, y_2 = 1$.",
          "Apply distance formula $d = \\sqrt{(x_2-x_1)^2 + (y_2-y_1)^2}$."
        ],
        "derivation": "$d = \\sqrt{(4-2)^2 + (1-3)^2} \\\\ d = \\sqrt{2^2 + (-2)^2} \\\\ d = \\sqrt{4+4} \\\\ d = \\sqrt{8} = 2\\sqrt{2}$"
      },
