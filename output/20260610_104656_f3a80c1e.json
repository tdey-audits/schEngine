    {
      "question": "The decimal expansion of the rational number $\\frac{147}{2^2 \\times 5^3 \\times 7}$ will terminate after how many places of decimals?",
      "answer": "(B)",
      "solution": {
        "steps": [
          "Simplify the fraction by dividing numerator and denominator by 7.",
          "Identify the prime factors of the denominator in the simplified form.",
          "Determine the number of decimal places based on the maximum power of 2 or 5."
        ],
        "derivation": "$\\frac{147}{2^2 \\times 5^3 \\times 7} = \\frac{21}{2^2 \\times 5^3} = \\frac{21 \\times 2}{2^3 \\times 5^3} = \\frac{42}{1000} = 0.042$ \\\\ The number of decimal places is 3."
      },
      "topic": "Real Numbers",
      "subtopic": "Decimal expansion of rational numbers",
      "marks": 1,
      "type": "mcq",
      "difficulty": "simple",
      "options": [
        "(A) 2",
        "(B) 3",
        "(C) 4",
        "(D) 5"
      ],
