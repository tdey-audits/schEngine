    {
      "question": "If the HCF of $65$ and $117$ is expressible in the form $65m - 117$, then the value of $m$ is:",
      "answer": "(A)",
      "solution": {
        "steps": [
          "Find the HCF of 65 and 117 using prime factorization.",
          "Equate the HCF to the expression $65m - 117$.",
          "Solve for $m$."
        ],
        "derivation": "$65 = 5 \\times 13$ \\\\ $117 = 9 \\times 13 = 3^2 \\times 13$ \\\\ $\\text{HCF} = 13$ \\\\ $65m - 117 = 13$ \\\\ $65m = 130$ \\\\ $m = 2$"
      },
      "topic": "Real Numbers",
      "subtopic": "Euclid's Division Lemma / HCF",
      "marks": 1,
      "type": "mcq",
      "difficulty": "simple",
      "options": [
        "(A) 2",
        "(B) 3",
        "(C) 4",
        "(D) 1"
      ],
