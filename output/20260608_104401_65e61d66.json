    {
      "question": "Find the greatest number of 6 digits which is exactly divisible by $12, 15,$ and $20$.",
      "answer": "$999960$",
      "solution": {
        "steps": [
          "Find the LCM of $12, 15,$ and $20$.",
          "$12 = 2^2 \\times 3$, $15 = 3 \\times 5$, $20 = 2^2 \\times 5$.",
          "$LCM = 2^2 \\times 3 \\times 5 = 60$.",
          "Identify the largest 6-digit number as $999999$.",
          "Divide $999999$ by $60$ and find the remainder.",
          "Subtract the remainder from $999999$ to get the largest divisible number."
        ],
        "derivation": "$LCM(12, 15, 20) = 60 \\\\ 999999 \\div 60 = 16666 \\text{ with remainder } 39 \\\\ 999999 - 39 = 999960$"
      },
