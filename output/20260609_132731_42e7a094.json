    {
      "question": "The decimal expansion of the rational number $\\frac{147}{2^2 \\times 5^7 \\times 3}$ will terminate after how many places of decimals?",
      "answer": "(B)",
      "solution": {
        "steps": [
          "Simplify the fraction by canceling the common factor $3$ from the numerator and denominator.",
          "Factorize $147$ as $3 \\times 49$.",
          "The denominator after simplification becomes $2^2 \\times 5^7$.",
          "To make the denominator a power of $10$, multiply both numerator and denominator by $5^5$ to match powers of $2$ and $5$.",
          "The number of decimal places is equal to the exponent of the power of $10$ in the denominator."
        ],
        "derivation": "\\frac{147}{2^2 \\times 5^7 \\times 3} = \\frac{49}{2^2 \\times 5^7} \\\\ \\text{The denominator is } 2^m \\times 5^n \\text{ where } m=2, n=7. \\\\ \\text{The number of decimal places is } \\max(m, n) = \\max(2, 7) = 7."
      },
      "topic": "Real Numbers",
      "subtopic": "Decimal Expansion",
      "marks": 1,
      "type": "mcq",
      "difficulty": "simple",
      "options": [
        "(A) $2$",
        "(B) $7$",
        "(C) $5$",
        "(D) $9$"
      ],
