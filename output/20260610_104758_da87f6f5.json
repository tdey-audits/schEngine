    {
      "question": "Find the greatest number that divides $108$ and $192$ leaving remainders $12$ and $6$ respectively.",
      "answer": "$48$",
      "solution": {
        "steps": [
          "Subtract the remainders from the given numbers: $108 - 12 = 96$ and $192 - 6 = 186$.",
          "Find the HCF of $96$ and $186$ using prime factorization.",
          "Prime factorize $96 = 2^5 \\times 3$ and $186 = 2 \\times 3 \\times 31$.",
          "Identify the common factors to get HCF = $2 \\times 3 = 6$."
        ],
        "derivation": "$108 - 12 = 96 \\\\ 192 - 6 = 186 \\\\ 96 = 2^5 \\times 3 \\\\ 186 = 2 \\times 3 \\times 31 \\\\ \\text{HCF}(96, 186) = 2^1 \\times 3^1 = 6$"
      },
      "topic": "Real Numbers",
      "subtopic": "HCF and LCM",
