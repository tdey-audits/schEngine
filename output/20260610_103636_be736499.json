      "marks": 4,
      "questions": [
        {
          "id": "i",
          "type": "mcq",
          "question": "Which of the following is the correct application of Euclid's division lemma for the first step to find the HCF of $468$ and $396$?",
          "answer": "(B)",
          "solution": {
            "steps": [
              "Apply $a = bq + r$ where $a = 468$ and $b = 396$.",
              "$468 = 396 \\times 1 + 72$."
            ],
            "derivation": "$468 = 396 \\times 1 + 72$"
          },
          "options": [
            "(A) $468 = 396 \\times 0 + 468$",
            "(B) $468 = 396 \\times 1 + 72$",
            "(C) $396 = 468 \\times 1 - 72$",
            "(D) $468 = 396 \\times 2 + 72$"
          ]
        },
        {
          "id": "ii",
          "type": "vsa",
          "question": "Find the HCF of $468$ and $396$ using Euclid's division algorithm.",
          "answer": "$36$",
          "solution": {
            "steps": [
              "Step 1: $468 = 396 \\times 1 + 72$",
              "Step 2: $396 = 72 \\times 5 + 36$",
              "Step 3: $72 = 36 \\times 2 + 0$",
              "Remainder is $0$, divisor is $36$."
            ],
            "derivation": "$468 = 396(1) + 72 \\\\ 396 = 72(5) + 36 \\\\ 72 = 36(2) + 0 \\\\ \\text{HCF} = 36$"
          }
        },
        {
          "id": "iii",
          "type": "mcq",
          "question": "If the number of items per pack is $k$, what is the total number of packets distributed if all $864$ people are served?",
          "answer": "(C)",
          "solution": {
            "steps": [
              "Total people = $468 + 396 = 864$.",
              "Each person receives one pack.",
              "Total packets = Total people = $864$."
