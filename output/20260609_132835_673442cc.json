    {
      "question": "In a school event, three batches of students are participating in a relay race. The lengths of the track segments assigned to the batches are $120$ cm, $180$ cm, and $300$ cm respectively. The organizers want to mark the track with flags at equal intervals such that the distance between any two flags is the same and the largest possible distance is used. Let $d$ be the distance between two flags.",
      "type": "case_study",
      "marks": 4,
      "questions": [
        {
          "id": "i",
          "type": "mcq",
          "question": "What is the value of $d$?",
          "answer": "(B)",
          "options": [
            "(A) 30 cm",
            "(B) 60 cm",
            "(C) 90 cm",
            "(D) 120 cm"
          ],
          "solution": {
            "steps": [
              "Find HCF of 120, 180, 300.",
              "120 = 2^3 * 3 * 5.",
              "180 = 2^2 * 3^2 * 5.",
              "300 = 2^2 * 3 * 5^2.",
              "HCF = 2^2 * 3 * 5 = 60."
            ],
            "derivation": "$120 = 2^3 \\times 3 \\times 5 \\\\ 180 = 2^2 \\times 3^2 \\times 5 \\\\ 300 = 2^2 \\times 3 \\times 5^2 \\\\ HCF = 2^2 \\times 3 \\times 5 = 60$"
          }
        },
        {
          "id": "ii",
          "type": "vsa",
          "question": "How many flags are required for the $120$ cm segment if flags are placed at both ends?",
          "answer": "$3$",
          "solution": {
            "steps": [
              "Number of intervals = $120 / 60 = 2$.",
              "Number of flags = intervals + 1 = 3."
            ],
            "derivation": "$n = \\frac{120}{60} + 1 = 2 + 1 = 3$"
          }
        },
        {
          "id": "iii",
          "type": "vsa",
          "question": "Find the total number of flags required for the $300$ cm segment.",
          "answer": "$6$",
          "solution": {
            "steps": [
              "Number of intervals = $300 / 60 = 5$.",
              "Number of flags = 5 + 1 = 6."
            ],
            "derivation": "$n = \\frac{300}{60} + 1 = 5 + 1 = 6$"
          }
        },
        {
          "id": "iv",
          "type": "mcq",
          "question": "If a new segment of length $x$ cm is added such that $d$ remains the HCF of $120, 180, 300,$ and $x$, which of the following could be $x$?",
          "answer": "(C)",
          "options": [
            "(A) 70",
            "(B) 80",
            "(C) 420",
            "(D) 100"
          ],
          "solution": {
            "steps": [
              "The HCF of 120, 180, 300 is 60. For the HCF to remain 60, $x$ must be a multiple of 60.",
              "Check options."
            ],
            "derivation": "$x \\text{ must be a multiple of } 60. \\\\ 420 = 7 \\times 60. \\\\ \\text{Therefore, } 420 \\text{ is a valid option.}$"
          }
        }
      ],
