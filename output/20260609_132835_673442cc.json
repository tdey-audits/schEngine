    {
      "question": "A packaging unit receives two consignments of items: $1260$ units of item $A$ and $1980$ units of item $B$. The manager wants to pack these into identical cartons such that each carton contains only one type of item and the maximum possible number of items are packed in each carton, with no items leftover. Let $H$ be the maximum number of items in each carton and $L$ be the total number of cartons if all items were of type $A$ packed in cartons of size $H$.",
      "type": "case_study",
      "marks": 4,
      "questions": [
        {
          "id": "i",
          "type": "mcq",
          "question": "What is the value of $H$, the maximum number of items per carton?",
          "answer": "(C)",
          "options": [
            "(A) 90",
            "(B) 120",
            "(C) 180",
            "(D) 360"
          ],
          "solution": {
            "steps": [
              "Find the HCF of 1260 and 1980.",
              "Prime factorisation of 1260 = 2^2 * 3^2 * 5 * 7.",
              "Prime factorisation of 1980 = 2^2 * 3^2 * 5 * 11.",
              "HCF = 2^2 * 3^2 * 5 = 4 * 9 * 5 = 180."
            ],
            "derivation": "$1260 = 2^2 \\times 3^2 \\times 5 \\times 7 \\\\ 1980 = 2^2 \\times 3^2 \\times 5 \\times 11 \\\\ HCF = 2^2 \\times 3^2 \\times 5 = 180$"
          }
        },
        {
          "id": "ii",
          "type": "vsa",
          "question": "Calculate the value of $L$.",
          "answer": "$7$",
          "solution": {
            "steps": [
              "Divide the total number of items A by H."
            ],
            "derivation": "$L = \\frac{1260}{180} = 7$"
          }
        },
        {
          "id": "iii",
          "type": "vsa",
          "question": "If the number of cartons for item B is denoted by $K$, find the value of $K$.",
          "answer": "$11$",
          "solution": {
            "steps": [
              "Divide the total number of items B by H."
            ],
            "derivation": "$K = \\frac{1980}{180} = 11$"
          }
        },
        {
          "id": "iv",
          "type": "mcq",
          "question": "Which of the following is true regarding the decimal expansion of $\\frac{1}{H}$?",
          "answer": "(A)",
          "options": [
            "(A) Terminating",
            "(B) Non-terminating repeating",
            "(C) Non-terminating non-repeating",
            "(D) None of these"
          ],
          "solution": {
            "steps": [
              "Check prime factors of denominator $H=180$.",
              "$180 = 2^2 * 3^2 * 5$.",
              "Since it contains prime factors other than 2 and 5, it is non-terminating repeating."
            ],
            "derivation": "$180 = 2^2 \\times 3^2 \\times 5^1 \\\\ \\text{Since } 3 \\text{ is a factor of the denominator, it is non-terminating repeating.}$"
          }
        }
      ],
