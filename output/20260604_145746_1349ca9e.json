    {
      "question": "Prove that the tangents drawn at the ends of a diameter of a circle are parallel.",
      "answer": "The tangents are parallel because their alternate interior angles sum to $180^\\circ$.",
      "solution": {
        "steps": [
          "Let $AB$ be a diameter and $PQ$ and $RS$ be tangents at $A$ and $B$ respectively.",
          "Since radius is perpendicular to the tangent at the point of contact, $\\angle OAP = 90^\\circ$ and $\\angle OBS = 90^\\circ$.",
          "Thus $\\angle OAP = \\angle OBS$, which are alternate interior angles.",
          "Since alternate interior angles are equal, the lines $PQ$ and $RS$ must be parallel."
        ],
        "derivation": "\\angle OAP = 90^\\circ \\\\ \\angle OBS = 90^\\circ \\\\ \\angle OAP = \\angle OBS \\\\ PQ \\parallel RS"
      },
