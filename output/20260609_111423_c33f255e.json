        {
          "id": "iii",
          "type": "vsa",
          "question": "What is the discriminant of the quadratic equation $2x^2 - 3x - 82 = 0$?",
          "answer": "$665$",
          "solution": {
            "steps": [
              "Identify $a=2, b=-3, c=-82$.",
              "Calculate $D = b^2 - 4ac$.",
              "$D = (-3)^2 - 4(2)(-82) = 9 + 656 = 665$."
            ],
            "derivation": "$D = (-3)^2 - 4 \\times 2 \\times (-82) = 9 + 656 = 665$"
          }
        },
        {
          "id": "iv",
          "type": "vsa",
          "question": "If the outer area of the garden is $119$ m$^2$, find the width $x$.",
          "answer": "$x = 7$",
          "solution": {
            "steps": [
              "Outer area $= x(2x+3) = 119$.",
              "$2x^2 + 3x - 119 = 0$.",
              "Factorise: $2x^2 + 17x - 14x - 119 = 0$.",
              "$x(2x+17) - 7(2x+17) = 0$.",
              "$(x-7)(2x+17) = 0$. Since $x > 0$, $x = 7$."
