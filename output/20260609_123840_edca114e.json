    {
      "question": "The decimal expansion of the rational number $\\frac{43}{2^4 \\times 5^3}$ will terminate after how many places of decimal?",
      "answer": "(B)",
      "solution": {
        "steps": [
          "The number of decimal places for a terminating decimal $\\frac{p}{2^n \\times 5^m}$ is equal to the maximum of $n$ and $m$.",
          "Here, $n=4$ and $m=3$.",
          "The maximum of $4$ and $3$ is $4$."
        ],
        "derivation": "\\frac{p}{2^n \\times 5^m} \\text{ terminates after } \\max(n, m) \\text{ places} \\ \\max(4, 3) = 4"
      },
      "topic": "Real Numbers",
      "subtopic": "Decimal Expansion",
      "marks": 1,
      "type": "mcq",
      "difficulty": "simple",
      "options": [
        "(A) 3",
        "(B) 4",
        "(C) 2",
        "(D) 1"
      ],
