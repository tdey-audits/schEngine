    {
      "question": "If the HCF of two numbers $a$ and $b$ is $12$ and their product is $1800$, then their LCM is:",
      "answer": "(C)",
      "solution": {
        "steps": [
          "Use the property $HCF(a, b) \times LCM(a, b) = a \times b$",
          "Substitute the given values: $12 \times LCM = 1800$",
          "Solve for $LCM = 1800 / 12 = 150$"
        ],
        "derivation": "$HCF \times LCM = a \times b \\ 12 \times LCM = 1800 \\ LCM = \\frac{1800}{12} \\ LCM = 150$"
      },
      "topic": "Real Numbers",
      "subtopic": "Fundamental Theorem of Arithmetic",
      "marks": 1,
      "type": "mcq",
      "difficulty": "simple",
      "options": [
        "(A) 120",
        "(B) 140",
        "(C) 150",
        "(D) 160"
      ],
