    {
      "question": "If $p$ and $q$ are two prime numbers, then the HCF of $p^3q^2$ and $p^2q$ is:",
      "answer": "(A)",
      "solution": {
        "steps": [
          "The HCF of two numbers is the product of the lowest powers of common prime factors.",
          "Common prime factors are $p$ and $q$.",
          "Lowest power of $p$ is $p^2$.",
          "Lowest power of $q$ is $q^1$."
        ],
        "derivation": "HCF(p^3q^2, p^2q) = p^{\\min(3,2)} \\times q^{\\min(2,1)} = p^2q"
      },
      "topic": "Real Numbers",
      "subtopic": "Prime Factorisation",
      "marks": 1,
      "type": "mcq",
      "difficulty": "simple",
      "options": [
        "(A) p^2q",
        "(B) p^3q^2",
        "(C) pq",
        "(D) p^2q^2"
      ],
