    {
      "question": "If $\\sin A = \\cos A$, where $0 < A < 90^\\circ$, find the value of $A$.",
      "answer": "$45^\\circ$",
      "solution": {
        "steps": [
          "Divide both sides by $\\cos A$ to get $\\tan A = 1$.",
          "Identify the angle where $\\tan A = 1$ in the given range."
        ],
        "derivation": "\\frac{\\sin A}{\\cos A} = 1 \\implies \\tan A = 1 \\implies A = \\tan^{-1}(1) = 45^\\circ"
      },
