      "marks": 4,
      "questions": [
        {
          "id": "i",
          "type": "mcq",
          "question": "If we let $u = \\frac{1}{R_1}$ and $v = \\frac{1}{R_2}$, which of the following represents the linear system in terms of $u$ and $v$?",
