  "questions": [
    {
      "question": "A design engineer is planning to construct a rectangular garden within a community park. The length of the garden is planned to be $3 \\text{ m}$ more than twice its width. The area of the garden is specified to be $119 \\text{ m}^2$. Let the width of the garden be $x$ meters.",
      "type": "case_study",
      "marks": 4,
      "questions": [
        {
          "id": "i",
          "type": "mcq",
          "question": "Which of the following quadratic equations represents the given situation?",
          "answer": "(A)",
          "options": [
            "(A) $2x^2 + 3x - 119 = 0$",
            "(B) $2x^2 - 3x - 119 = 0$",
            "(C) $x^2 + 3x - 119 = 0$",
            "(D) $2x^2 + 3x + 119 = 0$"
          ]
        },
        {
          "id": "ii",
          "type": "vsa",
          "question": "Find the discriminant $D$ of the quadratic equation obtained in part (i).",
          "answer": "$961$",
          "solution": {
            "steps": [
              "The equation is $2x^2 + 3x - 119 = 0$.",
              "Identify $a = 2$, $b = 3$, $c = -119$.",
              "Use $D = b^2 - 4ac$.",
              "$D = (3)^2 - 4(2)(-119) = 9 + 952 = 961$."
            ],
            "derivation": "$D = b^2 - 4ac \\\\ D = (3)^2 - 4(2)(-119) \\\\ D = 9 + 952 \\\\ D = 961$"
          }
        },
        {
          "id": "iii",
          "type": "mcq",
          "question": "What is the width of the garden in meters?",
          "answer": "(C)",
          "options": [
            "(A) $6 \\text{ m}$",
            "(B) $6.5 \\text{ m}$",
            "(C) $7 \\text{ m}$",
            "(D) $8.5 \\text{ m}$"
          ]
        },
        {
          "id": "iv",
          "type": "vsa",
          "question": "Determine the length of the garden.",
          "answer": "$17 \\text{ m}$",
          "solution": {
            "steps": [
              "Width $x = 7$.",
              "Length $L = 2x + 3$.",
              "$L = 2(7) + 3 = 14 + 3 = 17$."
            ],
            "derivation": "$L = 2(7) + 3 \\\\ L = 14 + 3 \\\\ L = 17$"
          }
        }
      ],
