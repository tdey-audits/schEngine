        ],
        "derivation": "\\frac{\\tan(90^\\circ - 25^\\circ)}{\\cot 25^\\circ} + \\left(\\frac{1}{2}\\right)^2 \\\\ = \\frac{\\cot 25^\\circ}{\\cot 25^\\circ} + \\frac{1}{4} \\\\ = 1 + 0.25 = 1.25"
