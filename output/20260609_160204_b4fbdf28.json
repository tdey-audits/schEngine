      "questions": [
        {
          "id": "i",
          "type": "mcq",
          "question": "Which trigonometric ratio is most appropriate to relate the height $h$ of the tower and the distance $x$ from point $P$ to the base $B$?",
          "answer": "(A)",
          "options": [
            "(A) $\\tan 60^\\circ = h/x$",
            "(B) $\\sin 60^\\circ = h/x$",
            "(C) $\\cos 60^\\circ = h/x$",
            "(D) $\\cot 60^\\circ = h/x$"
          ],
          "solution": {
            "steps": [
              "In $\\triangle ABP$, the side opposite to $\\angle APB$ is $AB=h$ and the adjacent side is $PB=x$.",
              "The ratio of opposite to adjacent is $\\tan \\theta$."
            ],
            "derivation": "$\\tan(60^\\circ) = \\frac{AB}{PB} = \\frac{h}{x}$"
          }
        },
        {
          "id": "ii",
          "type": "vsa",
          "question": "Express the distance $BQ$ in terms of $x$.",
          "answer": "$x+40$",
          "solution": {
            "steps": [
              "Points $Q$, $P$, and $B$ lie on a straight line in that order.",
              "$BQ = QP + PB$."
            ],
            "derivation": "$BQ = 40 + x$"
          }
        },
        {
          "id": "iii",
          "type": "vsa",
          "question": "Find the height $h$ of the tower in meters.",
          "answer": "$20\\sqrt{3}$",
          "solution": {
            "steps": [
              "From $\\triangle ABP$, $x = h/\\tan 60^\\circ = h/\\sqrt{3}$.",
              "From $\\triangle ABQ$, $x+40 = h/\\tan 30^\\circ = h\\sqrt{3}$.",
              "Substitute $x$: $h/\\sqrt{3} + 40 = h\\sqrt{3}$.",
              "Solve for $h$: $40 = h(\\sqrt{3} - 1/\\sqrt{3}) = h(2/\\sqrt{3})$.",
              "$h = 20\\sqrt{3}$."
            ],
            "derivation": "h = \\frac{40}{\\sqrt{3} - \\frac{1}{\\sqrt{3}}} = \\frac{40\\sqrt{3}}{2} = 20\\sqrt{3}"
          }
        },
        {
          "id": "iv",
          "type": "vsa",
          "question": "What is the distance $PB$ (the distance of the first observation point from the base)?",
          "answer": "$20$",
          "solution": {
            "steps": [
              "Using $h = 20\\sqrt{3}$ and $x = h/\\sqrt{3}$.",
              "$x = (20\\sqrt{3})/\\sqrt{3} = 20$."
            ],
            "derivation": "x = \\frac{20\\sqrt{3}}{\\sqrt{3}} = 20"
          }
        }
