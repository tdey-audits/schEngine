  "questions": [
    {
      "question": "If two positive integers $a$ and $b$ are written as $a = x^3 y^2$ and $b = x y^3$, where $x$ and $y$ are prime numbers, then the $HCF(a, b)$ is:",
      "answer": "(B)",
      "solution": {
        "steps": [
          "Find the common prime factors with their lowest exponents.",
          "The prime factors of $a$ are $x, x, x, y, y$.",
          "The prime factors of $b$ are $x, y, y, y$.",
          "The common factors are one $x$ and two $y$s, i.e., $x y^2$."
        ],
        "derivation": "$a = x^3 y^2 \\\\ b = x y^3 \\\\ HCF(a, b) = x^{\\min(3, 1)} \\times y^{\\min(2, 3)} = x y^2$"
      },
      "topic": "Real Numbers",
      "subtopic": "Fundamental Theorem of Arithmetic",
      "marks": 1,
      "type": "mcq",
      "difficulty": "simple",
      "options": [
        "(A) $x^3 y^3$",
        "(B) $x y^2$",
        "(C) $x^2 y^2$",
        "(D) $x^3 y^3$"
      ],
