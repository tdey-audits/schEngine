    {
      "question": "The largest number which divides $70$ and $125$ leaving remainders $5$ and $8$ respectively is:",
      "answer": "(A)",
      "solution": {
        "steps": [
          "Subtract the remainders from the numbers: $70 - 5 = 65$ and $125 - 8 = 117$.",
          "Find the HCF of $65$ and $117$.",
          "$65 = 5 \\times 13$ and $117 = 9 \\times 13$. HCF = $13$."
        ],
        "derivation": "70 - 5 = 65 \\\\ 125 - 8 = 117 \\\\ HCF(65, 117) = 13"
      },
      "topic": "Real Numbers",
      "subtopic": "HCF and LCM Applications",
      "marks": 1,
      "type": "mcq",
      "difficulty": "simple",
      "options": [
        "(A) 13",
        "(B) 9",
        "(C) 5",
        "(D) 17"
      ],
