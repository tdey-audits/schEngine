    {
      "question": "If $p$ and $q$ are two prime numbers, then their $LCM$ is:",
      "answer": "(D)",
      "solution": {
        "steps": [
          "For any two prime numbers, they have no common factors other than 1.",
          "The LCM of two co-prime numbers is their product."
        ],
        "derivation": "LCM(p, q) = \\frac{p \\times q}{HCF(p, q)} = \\frac{p \\times q}{1} = pq"
      },
      "topic": "Real Numbers",
      "subtopic": "Fundamental Theorem of Arithmetic",
      "marks": 1,
      "type": "mcq",
      "difficulty": "simple",
      "options": [
        "(A) 1",
        "(B) $p$",
        "(C) $q$",
        "(D) $pq$"
      ],
